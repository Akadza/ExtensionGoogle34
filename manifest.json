{
  "manifest_version": 3,
  "name": "R34 Visual Filter",
  "version": "0.1.0",
  "description": "Visual improvements and local filters for rule34.xxx",
  "permissions": ["storage"],
  "host_permissions": [
    "https://rule34.xxx/*",
    "http://rule34.xxx/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://rule34.xxx/*",
        "http://rule34.xxx/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "R34 Visual Filter"
  }
}